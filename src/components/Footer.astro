---
import { getNavLinks, getStrings, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getStrings(lang);
const navLinks = getNavLinks(lang);
---
<footer class="bg-white text-text" role="contentinfo">
  <!-- Top accent line -->
  <div class="h-1 bg-gradient-to-r from-primary via-primary/60 to-primary"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- About column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`/${lang}/`} class="inline-flex items-center gap-3 mb-5" aria-label="Bafcon">
          <img src="/images/bafcon-logo.png" alt="Bafcon logo" class="w-9 h-9 rounded-full object-cover shrink-0" />
          <span class="text-text font-display text-xl font-semibold tracking-wide">BAFCON</span>
        </a>
        <p class="text-muted text-sm leading-relaxed font-body max-w-xs">
          {t.footer.description}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-text font-display text-lg font-semibold mb-5">{t.footer.quick_links}</h3>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-muted hover:text-primary transition-colors duration-200 text-sm font-body">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div>
        <h3 class="text-text font-display text-lg font-semibold mb-5">{t.footer.contact_info}</h3>
        <ul class="space-y-3 text-sm font-body">
          <li>
            <a href="tel:+994518857777" class="text-muted hover:text-primary transition-colors duration-200 flex items-center gap-2">
              <svg class="w-4 h-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              +994 51 885 77 77
            </a>
          </li>
          <li class="text-muted flex items-start gap-2">
            <svg class="w-4 h-4 shrink-0 text-primary mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Bak&#305;, Nizami rayonu,<br />&#350;irin Mirz&#601;yev k&#252;&#231;&#601;si</span>
          </li>
          <li class="text-muted flex items-center gap-2">
            <svg class="w-4 h-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {t.contact.hours_value}
          </li>
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="text-text font-display text-lg font-semibold mb-5">{t.footer.follow}</h3>
        <div class="flex items-center gap-3">
          <a
            href="https://wa.me/994518857777"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 flex items-center justify-center rounded-full bg-surface hover:bg-primary/20 text-muted hover:text-primary transition-all duration-200"
            aria-label="WhatsApp"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/bafcon_design/"
            target="_blank"
            rel="noopener noreferrer"
            class="w-11 h-11 flex items-center justify-center rounded-full bg-surface hover:bg-primary/20 text-muted hover:text-primary transition-all duration-200"
            aria-label="Instagram @bafcon_design"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-muted text-sm font-body">
        &copy; 2026 BAFCON. {t.footer.rights}.
      </p>
      <p class="text-muted/50 text-xs font-body">
        T&#601;mir &middot; Tikinti &middot; Mebel
      </p>
    </div>
  </div>
</footer>
