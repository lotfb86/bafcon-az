---
import { getStrings, pageRoutes, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getStrings(lang);
---
<section class="py-20 lg:py-28 bg-surface" id="services-overview">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal mb-14 lg:mb-20">
      <p class="text-primary font-body text-sm tracking-[0.3em] uppercase mb-3">
        {t.services_section.title}
      </p>
      <h2 class="font-display font-bold text-text" style="font-size: clamp(2rem, 3vw + 1rem, 3rem)">
        {t.services_section.title}
      </h2>
      <div class="w-16 h-0.5 bg-primary mt-4"></div>
    </div>

    <!-- Asymmetric layout: featured left, two stacked right -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-8">
      <!-- Featured card: Renovation -->
      <div class="reveal lg:col-span-3 group relative overflow-hidden rounded-sm bg-white shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1">
        <div class="aspect-[4/3] lg:aspect-[16/10] overflow-hidden">
          <img
            src="/images/services/renovation.jpg"
            alt={t.services_section.renovation}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
        </div>
        <div class="p-6 lg:p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
              <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085" />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-2xl text-text">{t.services_section.renovation}</h3>
          </div>
          <p class="text-muted font-body leading-relaxed mb-6">{t.services_section.renovation_desc}</p>
          <a href={pageRoutes.services[lang]} class="inline-flex items-center gap-2 text-primary font-body font-medium text-sm hover:gap-3 transition-all duration-200">
            {t.services_section.learn_more}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right stack -->
      <div class="lg:col-span-2 flex flex-col gap-6 lg:gap-8">
        <!-- Construction card -->
        <div class="reveal reveal-delay-1 group relative overflow-hidden rounded-sm bg-white shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1 flex-1">
          <div class="p-6 lg:p-8 h-full flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
                </svg>
              </div>
              <h3 class="font-display font-semibold text-xl text-text">{t.services_section.construction}</h3>
            </div>
            <p class="text-muted font-body text-sm leading-relaxed mb-5 flex-1">{t.services_section.construction_desc}</p>
            <a href={pageRoutes.services[lang]} class="inline-flex items-center gap-2 text-primary font-body font-medium text-sm hover:gap-3 transition-all duration-200">
              {t.services_section.learn_more}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Furniture card -->
        <div class="reveal reveal-delay-2 group relative overflow-hidden rounded-sm bg-white shadow-sm hover:shadow-xl transition-all duration-500 hover:-translate-y-1 flex-1">
          <div class="p-6 lg:p-8 h-full flex flex-col">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
                <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                </svg>
              </div>
              <h3 class="font-display font-semibold text-xl text-text">{t.services_section.furniture}</h3>
            </div>
            <p class="text-muted font-body text-sm leading-relaxed mb-5 flex-1">{t.services_section.furniture_desc}</p>
            <a href={pageRoutes.services[lang]} class="inline-flex items-center gap-2 text-primary font-body font-medium text-sm hover:gap-3 transition-all duration-200">
              {t.services_section.learn_more}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
