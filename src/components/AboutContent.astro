---
import { getStrings, pageRoutes, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getStrings(lang);
---
<!-- Page hero -->
<section class="relative py-24 lg:py-32 bg-white overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <img src="/images/about/office.jpg" alt="" class="w-full h-full object-cover" loading="eager" />
  </div>
  <div class="absolute inset-0 bg-white/80"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-display font-bold text-text mb-4" style="font-size: clamp(2.5rem, 4vw + 1rem, 4rem)">
      {t.about.title}
    </h1>
    <div class="w-16 h-0.5 bg-primary mx-auto"></div>
  </div>
</section>

<!-- Story section: text left, image right -->
<section class="py-20 lg:py-28 bg-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="reveal">
        <p class="text-primary font-body text-sm tracking-[0.3em] uppercase mb-4">{t.about.story_title}</p>
        <h2 class="font-display font-bold text-text mb-6" style="font-size: clamp(1.75rem, 2.5vw + 0.5rem, 2.5rem)">
          {t.about.story_title}
        </h2>
        <p class="text-muted font-body leading-relaxed mb-6 text-base">{t.about.story}</p>
        <p class="text-text font-body leading-relaxed text-base italic border-l-2 border-primary pl-6">
          {t.about.mission}
        </p>
      </div>
      <div class="reveal reveal-delay-2 relative">
        <img
          src="/images/about/office.jpg"
          alt="Bafcon office"
          class="w-full rounded-sm shadow-xl"
          loading="lazy"
        />
        <!-- Decorative element -->
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border-2 border-primary rounded-sm -z-10 hidden lg:block" aria-hidden="true"></div>
      </div>
    </div>
  </div>
</section>

<!-- Why Bafcon: alternating layout -->
<section class="py-20 lg:py-28 bg-surface">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal text-center mb-14 lg:mb-20">
      <h2 class="font-display font-bold text-text" style="font-size: clamp(2rem, 3vw + 1rem, 3rem)">
        {t.about.why_title}
      </h2>
      <div class="w-16 h-0.5 bg-primary mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 lg:gap-8 max-w-4xl mx-auto">
      {[t.about.why1, t.about.why2, t.about.why3, t.about.why4].map((item, i) => (
        <div class={`reveal reveal-delay-${i + 1} bg-white p-8 rounded-sm shadow-sm hover:shadow-lg transition-shadow duration-500 flex items-start gap-4`}>
          <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <p class="font-body text-text text-base leading-relaxed">{item}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Blueprint/process image -->
<section class="py-20 lg:py-28 bg-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="reveal grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="order-2 lg:order-1">
        <img
          src="/images/about/blueprints.jpg"
          alt="Architectural blueprints"
          class="w-full rounded-sm shadow-xl"
          loading="lazy"
        />
      </div>
      <div class="order-1 lg:order-2">
        <div class="grid grid-cols-2 gap-6">
          <div class="text-center p-6 bg-surface rounded-sm">
            <p class="font-display font-bold text-primary text-4xl lg:text-5xl">700+</p>
            <p class="font-body text-muted text-sm mt-2">{t.stats.apartments}</p>
          </div>
          <div class="text-center p-6 bg-surface rounded-sm">
            <p class="font-display font-bold text-primary text-4xl lg:text-5xl">10+</p>
            <p class="font-body text-muted text-sm mt-2">{t.stats.years}</p>
          </div>
          <div class="text-center p-6 bg-surface rounded-sm">
            <p class="font-display font-bold text-primary text-4xl lg:text-5xl">50+</p>
            <p class="font-body text-muted text-sm mt-2">{lang === 'az' ? 'Peşəkar' : lang === 'ru' ? 'Специалистов' : 'Professionals'}</p>
          </div>
          <div class="text-center p-6 bg-surface rounded-sm">
            <p class="font-display font-bold text-primary text-4xl lg:text-5xl">3</p>
            <p class="font-body text-muted text-sm mt-2">{t.stats.services}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
