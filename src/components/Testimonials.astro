---
import { getStrings, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getStrings(lang);

const testimonials = {
  az: [
    { text: 'Qonaq otağımızı gördükdə gözlərimə inanmadım. 3D-də gördüyümüz şəkil ilə real nəticə demək olar eyni idi. 2 ayda hər şey hazır oldu. Bafcon-a minnətdarıq.', name: 'Nigar M.', project: '3 otaqlı mənzil, Nəsimi' },
    { text: 'Əvvəl 3 fərqli usta ilə işləmişdik — hamısı yarımçıq qoydu. Bafcon-da bir komanda hər şeyi etdi: elektrik, santexnika, mebel. Gözlənilməz xərc olmadı.', name: 'Elvin H.', project: '2 otaqlı mənzil, Yasamal' },
    { text: 'Mətbəximiz 15 illik idi. İndi qonaqlar gələndə soruşurlar: harada düzəldilib? Xüsusi ölçülü şkaflar tam yerinə oturdu. Dizayndan icraya qədər peşəkar iş.', name: 'Leyla A.', project: 'Mətbəx renovasiyası, Xətai' },
  ],
  ru: [
    { text: 'Когда увидела гостиную — не поверила глазам. 3D-картинка и реальность практически совпали. За 2 месяца всё было готово. Спасибо команде Bafcon.', name: 'Нигар М.', project: '3-комн. квартира, Насими' },
    { text: 'До этого работали с тремя мастерами — все бросили на полпути. В Bafcon одна команда сделала всё: электрику, сантехнику, мебель. Никаких скрытых расходов.', name: 'Эльвин Х.', project: '2-комн. квартира, Ясамал' },
    { text: 'Кухне было 15 лет. Теперь гости спрашивают: где вам это сделали? Шкафы по индивидуальным размерам встали идеально. От дизайна до установки — всё на уровне.', name: 'Лейла А.', project: 'Ремонт кухни, Хатаи' },
  ],
  en: [
    { text: 'When I saw the living room, I could not believe my eyes. The 3D render and the real result were nearly identical. Everything was done in 2 months. Thank you, Bafcon.', name: 'Nigar M.', project: '3-room apartment, Nasimi' },
    { text: 'We had worked with three different contractors before — all of them quit halfway. Bafcon handled everything: electrical, plumbing, furniture. No hidden costs.', name: 'Elvin H.', project: '2-room apartment, Yasamal' },
    { text: 'Our kitchen was 15 years old. Now guests ask: where did you get this done? Custom cabinets fit perfectly. From design to installation — professional work throughout.', name: 'Leyla A.', project: 'Kitchen renovation, Khatai' },
  ],
};

const currentTestimonials = testimonials[lang] || testimonials.az;
---
<section class="py-20 lg:py-28 bg-surface" id="testimonials">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal text-center mb-14 lg:mb-20">
      <p class="text-primary font-body text-sm tracking-[0.3em] uppercase mb-3">
        {t.testimonials.title}
      </p>
      <h2 class="font-display font-bold text-text" style="font-size: clamp(2rem, 3vw + 1rem, 3rem)">
        {t.testimonials.title}
      </h2>
      <div class="w-16 h-0.5 bg-primary mx-auto mt-4"></div>
    </div>

    <!-- Staggered testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
      {currentTestimonials.map((item, i) => (
        <div class:list={[
          'reveal',
          `reveal-delay-${i + 1}`,
          i === 1 ? 'md:-translate-y-6' : '',
          i === 2 ? 'md:translate-y-3' : ''
        ]}>
          <div class="bg-white rounded-sm p-8 lg:p-10 shadow-sm hover:shadow-lg transition-shadow duration-500 relative">
            <!-- Decorative quote mark -->
            <div class="absolute -top-4 left-8 text-primary/20" aria-hidden="true">
              <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
              </svg>
            </div>

            <!-- Quote text -->
            <blockquote class="relative pt-6">
              <p class="text-text font-body leading-relaxed text-base italic">
                &ldquo;{item.text}&rdquo;
              </p>
            </blockquote>

            <!-- Author -->
            <div class="mt-6 pt-6 border-t border-border flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                <span class="text-primary font-display font-bold text-sm">
                  {item.name.charAt(0)}
                </span>
              </div>
              <div>
                <p class="font-body font-medium text-text text-sm">{item.name}</p>
                <p class="font-body text-muted text-xs">{item.project}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
