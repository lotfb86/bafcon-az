---
import { getStrings, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getStrings(lang);

const testimonials = {
  az: [
    { text: 'İki il əvvəl köhnə mənzilimizə köçdük. İndi hər axşam qapını açanda ürəyim sevinir — sanki fərqli bir evə gəlirəm. Uşaqlar da öz otaqlarını çox sevirlər.', name: 'Nigar M.', project: '3 otaqlı mənzil, Nəsimi' },
    { text: 'Əvvəllər hər şeyi ayrı-ayrı ustalarla həll edirdik, çox yorucu idi. Bu dəfə bir komanda hər şeyi üzərinə götürdü — biz sadəcə nəticəni gözlədik. Rahat proses idi.', name: 'Elvin H.', project: '2 otaqlı mənzil, Yasamal' },
    { text: 'Mətbəximiz artıq bizim ailə məkanımızdır. Hər şey əlimin altındadır, dizayn tam istədiyim kimi oldu. İndi yeməyi daha çox sevə-sevə hazırlayıram.', name: 'Leyla A.', project: 'Mətbəx renovasiyası, Xətai' },
  ],
  ru: [
    { text: 'Два года назад переехали в старую квартиру. Теперь каждый вечер, открывая дверь, радуюсь — как будто это совершенно другой дом. Дети тоже обожают свои комнаты.', name: 'Нигар М.', project: '3-комн. квартира, Насими' },
    { text: 'Раньше всё решали с разными мастерами — это было очень утомительно. В этот раз одна команда взяла всё на себя — мы просто ждали результат. Спокойный процесс.', name: 'Эльвин Х.', project: '2-комн. квартира, Ясамал' },
    { text: 'Кухня теперь наше семейное место. Всё под рукой, дизайн именно такой, как я хотела. Теперь готовлю с удовольствием.', name: 'Лейла А.', project: 'Ремонт кухни, Хатаи' },
  ],
  en: [
    { text: 'We moved into an old apartment two years ago. Now every evening when I open the door, my heart smiles — it feels like a completely different home. The kids love their rooms too.', name: 'Nigar M.', project: '3-room apartment, Nasimi' },
    { text: 'Before, we dealt with different contractors for everything — it was exhausting. This time one team took care of it all — we just waited for the result. A stress-free process.', name: 'Elvin H.', project: '2-room apartment, Yasamal' },
    { text: 'Our kitchen is now our family space. Everything is within reach, the design is exactly what I wanted. I actually enjoy cooking now.', name: 'Leyla A.', project: 'Kitchen renovation, Khatai' },
  ],
};

const currentTestimonials = testimonials[lang] || testimonials.az;
---
<section class="py-20 lg:py-28 bg-white" id="testimonials">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal text-center mb-14 lg:mb-20">
      <p class="text-primary font-body text-sm tracking-[0.3em] uppercase mb-3">
        {t.testimonials.title}
      </p>
      <h2 class="font-display font-bold text-text" style="font-size: clamp(2rem, 3vw + 1rem, 3rem)">
        {t.testimonials.title}
      </h2>
      <div class="w-16 h-0.5 bg-primary mx-auto mt-4"></div>
    </div>

    <!-- Staggered testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
      {currentTestimonials.map((item, i) => (
        <div class:list={[
          'reveal',
          `reveal-delay-${i + 1}`,
          i === 1 ? 'md:-translate-y-6' : '',
          i === 2 ? 'md:translate-y-3' : ''
        ]}>
          <div class="bg-white rounded-sm p-8 lg:p-10 shadow-sm hover:shadow-lg transition-shadow duration-500 relative">
            <!-- Decorative quote mark -->
            <div class="absolute -top-4 left-8 text-primary/20" aria-hidden="true">
              <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
              </svg>
            </div>

            <!-- Quote text -->
            <blockquote class="relative pt-6">
              <p class="text-text font-body leading-relaxed text-base italic">
                &ldquo;{item.text}&rdquo;
              </p>
            </blockquote>

            <!-- Author -->
            <div class="mt-6 pt-6 border-t border-border flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                <span class="text-primary font-display font-bold text-sm">
                  {item.name.charAt(0)}
                </span>
              </div>
              <div>
                <p class="font-body font-medium text-text text-sm">{item.name}</p>
                <p class="font-body text-muted text-xs">{item.project}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
