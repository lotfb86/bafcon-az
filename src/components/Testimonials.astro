---
import { getStrings, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getStrings(lang);

const testimonials = {
  az: [
    { text: 'Bafcon komandas\u0131 m\u0259nzilimizi tamamilə d\u0259yi\u015fdirdi. H\u0259r detal z\u00f6vql\u0259 d\u00fc\u015f\u00fcn\u00fclm\u00fc\u015fd\u00fc.', name: 'Nigar M.', project: '3 otaql\u0131 m\u0259nzil' },
    { text: '10 illik t\u0259cr\u00fcb\u0259 \u00f6z\u00fcn\u00fc g\u00f6st\u0259rir. Keyfiyy\u0259tli i\u015f v\u0259 vaxt\u0131nda t\u0259hvil.', name: 'Elvin H.', project: '2 otaql\u0131 m\u0259nzil' },
    { text: '3D dizayn xidm\u0259ti say\u0259sind\u0259 n\u0259tic\u0259ni \u0259vv\u0259lc\u0259d\u0259n g\u00f6rd\u00fck. \u00c7ox raz\u0131y\u0131q.', name: 'Leyla A.', project: 'M\u0259tb\u0259x renovasiyas\u0131' },
  ],
  ru: [
    { text: '\u041a\u043e\u043c\u0430\u043d\u0434\u0430 Bafcon \u043f\u043e\u043b\u043d\u043e\u0441\u0442\u044c\u044e \u043f\u0440\u0435\u043e\u0431\u0440\u0430\u0437\u0438\u043b\u0430 \u043d\u0430\u0448\u0443 \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0443. \u041a\u0430\u0436\u0434\u0430\u044f \u0434\u0435\u0442\u0430\u043b\u044c \u043f\u0440\u043e\u0434\u0443\u043c\u0430\u043d\u0430 \u0441\u043e \u0432\u043a\u0443\u0441\u043e\u043c.', name: '\u041d\u0438\u0433\u0430\u0440 \u041c.', project: '3-\u043a\u043e\u043c\u043d\u0430\u0442\u043d\u0430\u044f \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430' },
    { text: '10 \u043b\u0435\u0442 \u043e\u043f\u044b\u0442\u0430 \u0433\u043e\u0432\u043e\u0440\u044f\u0442 \u0441\u0430\u043c\u0438 \u0437\u0430 \u0441\u0435\u0431\u044f. \u041a\u0430\u0447\u0435\u0441\u0442\u0432\u0435\u043d\u043d\u0430\u044f \u0440\u0430\u0431\u043e\u0442\u0430 \u0438 \u0441\u0434\u0430\u0447\u0430 \u0432 \u0441\u0440\u043e\u043a.', name: '\u042d\u043b\u044c\u0432\u0438\u043d \u0425.', project: '2-\u043a\u043e\u043c\u043d\u0430\u0442\u043d\u0430\u044f \u043a\u0432\u0430\u0440\u0442\u0438\u0440\u0430' },
    { text: '\u0411\u043b\u0430\u0433\u043e\u0434\u0430\u0440\u044f 3D-\u0432\u0438\u0437\u0443\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438 \u043c\u044b \u0443\u0432\u0438\u0434\u0435\u043b\u0438 \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0437\u0430\u0440\u0430\u043d\u0435\u0435. \u041e\u0447\u0435\u043d\u044c \u0434\u043e\u0432\u043e\u043b\u044c\u043d\u044b.', name: '\u041b\u0435\u0439\u043b\u0430 \u0410.', project: '\u0420\u0435\u043d\u043e\u0432\u0430\u0446\u0438\u044f \u043a\u0443\u0445\u043d\u0438' },
  ],
  en: [
    { text: 'The Bafcon team completely transformed our apartment. Every detail was thoughtfully designed.', name: 'Nigar M.', project: '3-room apartment' },
    { text: '10 years of experience speaks for itself. Quality work and on-time delivery.', name: 'Elvin H.', project: '2-room apartment' },
    { text: 'Thanks to the 3D design service, we saw the result beforehand. Very satisfied.', name: 'Leyla A.', project: 'Kitchen renovation' },
  ],
};

const currentTestimonials = testimonials[lang] || testimonials.az;
---
<section class="py-20 lg:py-28 bg-surface" id="testimonials">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="reveal text-center mb-14 lg:mb-20">
      <p class="text-primary font-body text-sm tracking-[0.3em] uppercase mb-3">
        {t.testimonials.title}
      </p>
      <h2 class="font-display font-bold text-text" style="font-size: clamp(2rem, 3vw + 1rem, 3rem)">
        {t.testimonials.title}
      </h2>
      <div class="w-16 h-0.5 bg-primary mx-auto mt-4"></div>
    </div>

    <!-- Staggered testimonial cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-10">
      {currentTestimonials.map((item, i) => (
        <div class:list={[
          'reveal',
          `reveal-delay-${i + 1}`,
          i === 1 ? 'md:-translate-y-6' : '',
          i === 2 ? 'md:translate-y-3' : ''
        ]}>
          <div class="bg-white rounded-sm p-8 lg:p-10 shadow-sm hover:shadow-lg transition-shadow duration-500 relative">
            <!-- Decorative quote mark -->
            <div class="absolute -top-4 left-8 text-primary/20" aria-hidden="true">
              <svg class="w-12 h-12" fill="currentColor" viewBox="0 0 24 24">
                <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
              </svg>
            </div>

            <!-- Quote text -->
            <blockquote class="relative pt-6">
              <p class="text-text font-body leading-relaxed text-base italic">
                &ldquo;{item.text}&rdquo;
              </p>
            </blockquote>

            <!-- Author -->
            <div class="mt-6 pt-6 border-t border-border flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center">
                <span class="text-primary font-display font-bold text-sm">
                  {item.name.charAt(0)}
                </span>
              </div>
              <div>
                <p class="font-body font-medium text-text text-sm">{item.name}</p>
                <p class="font-body text-muted text-xs">{item.project}</p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
