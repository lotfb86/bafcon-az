---
import { getStrings, type Lang } from '../utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getStrings(lang);
---
<!-- Page hero -->
<section class="relative py-24 lg:py-32 bg-white overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <img src="/images/contact/baku.jpg" alt="" class="w-full h-full object-cover" loading="eager" />
  </div>
  <div class="absolute inset-0 bg-white/80"></div>
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h1 class="font-display font-bold text-text mb-4" style="font-size: clamp(2.5rem, 4vw + 1rem, 4rem)">
      {t.contact.title}
    </h1>
    <div class="w-16 h-0.5 bg-primary mx-auto"></div>
  </div>
</section>

<!-- Contact content: form left, info right -->
<section class="py-20 lg:py-28 bg-bg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 lg:gap-16">
      <!-- Form (3 cols) -->
      <div class="reveal lg:col-span-3">
        <form class="space-y-6" action="#" method="POST">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block font-body text-sm font-medium text-text mb-2">{t.contact.name}</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 bg-white border border-border rounded-sm font-body text-text placeholder-muted/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                placeholder={t.contact.name}
              />
            </div>
            <div>
              <label for="phone" class="block font-body text-sm font-medium text-text mb-2">{t.contact.phone}</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full px-4 py-3 bg-white border border-border rounded-sm font-body text-text placeholder-muted/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
                placeholder="+994 XX XXX XX XX"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block font-body text-sm font-medium text-text mb-2">{t.contact.email}</label>
            <input
              type="email"
              id="email"
              name="email"
              class="w-full px-4 py-3 bg-white border border-border rounded-sm font-body text-text placeholder-muted/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"
              placeholder={t.contact.email}
            />
          </div>

          <div>
            <label for="service" class="block font-body text-sm font-medium text-text mb-2">{t.contact.service}</label>
            <select
              id="service"
              name="service"
              class="w-full px-4 py-3 bg-white border border-border rounded-sm font-body text-text focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors appearance-none"
            >
              <option value="">{t.contact.select_service}</option>
              <option value="renovation">{t.contact.renovation}</option>
              <option value="construction">{t.contact.construction}</option>
              <option value="furniture">{t.contact.furniture}</option>
              <option value="design">{t.contact.design}</option>
            </select>
          </div>

          <div>
            <label for="message" class="block font-body text-sm font-medium text-text mb-2">{t.contact.message}</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              class="w-full px-4 py-3 bg-white border border-border rounded-sm font-body text-text placeholder-muted/50 focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors resize-none"
              placeholder={t.contact.message}
            ></textarea>
          </div>

          <button
            type="submit"
            class="inline-flex items-center gap-3 bg-primary hover:bg-primary-hover text-bg-dark font-body font-medium px-8 py-4 rounded-sm transition-all duration-300 text-base shadow-lg hover:shadow-xl hover:-translate-y-0.5 min-w-[180px] justify-center"
          >
            {t.contact.send}
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
            </svg>
          </button>
        </form>
      </div>

      <!-- Contact Info (2 cols) -->
      <div class="reveal reveal-delay-2 lg:col-span-2">
        <div class="bg-surface rounded-sm p-8 lg:p-10 border border-border">
          <h2 class="font-display font-semibold text-text text-2xl mb-8">{t.footer.contact_info}</h2>

          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="font-body text-sm text-muted mb-1">{t.contact.phone}</p>
                <a href="tel:+994518857777" class="font-body font-medium text-text hover:text-primary transition-colors">+994 51 885 77 77</a>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <p class="font-body text-sm text-muted mb-1">{t.contact.address}</p>
                <p class="font-body text-text">Bak&#305;, Nizami rayonu,<br />&#350;irin Mirz&#601;yev k&#252;&#231;&#601;si</p>
              </div>
            </div>

            <!-- Hours -->
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-full bg-primary/10 flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <p class="font-body text-sm text-muted mb-1">{t.contact.hours}</p>
                <p class="font-body text-text">{t.contact.hours_value}</p>
              </div>
            </div>

            <!-- WhatsApp -->
            <div class="pt-6 border-t border-border">
              <a
                href="https://wa.me/994518857777"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#20bd5a] text-white font-body font-medium px-6 py-3 rounded-sm transition-all duration-300 text-sm w-full justify-center"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
