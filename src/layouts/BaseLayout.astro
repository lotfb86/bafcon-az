---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getAlternateLinks, type Lang } from '../utils/i18n';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  ogImage?: string;
}

const { title, description, lang, ogImage = '/images/hero/hero-interior.jpg' } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const alternates = getAlternateLinks(Astro.url.pathname);
---
<!DOCTYPE html>
<html lang={lang} class="antialiased">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl.href} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  {alternates.map(alt => (
    <link rel="alternate" hreflang={alt.lang} href={new URL(alt.url, Astro.site).href} />
  ))}
  <link rel="alternate" hreflang="x-default" href={new URL('/az/', Astro.site).href} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl.href} />
  <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
  <meta property="og:locale" content={lang === 'az' ? 'az_AZ' : lang === 'ru' ? 'ru_RU' : 'en_US'} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

  <meta name="theme-color" content="#1C1C1E" />
</head>
<body class="min-h-screen flex flex-col bg-bg text-text">
  <Header lang={lang} />
  <main id="main-content" class="flex-1">
    <slot />
  </main>
  <Footer lang={lang} />

  <script is:inline>
    // Scroll-triggered reveal animation
    // Content is visible by default (no JS). We add reveal-ready class
    // to <html> to enable animations only after observer is set up.
    function initReveal() {
      if (!('IntersectionObserver' in window)) return;

      // Mark all currently-in-viewport elements as visible BEFORE enabling animations
      var els = document.querySelectorAll('.reveal');
      var viewH = window.innerHeight;
      els.forEach(function(el) {
        var rect = el.getBoundingClientRect();
        if (rect.top < viewH + 50) {
          el.classList.add('visible');
        }
      });

      // Now enable the animation CSS
      document.documentElement.classList.add('reveal-ready');

      // Observe remaining elements
      var observer = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.05, rootMargin: '0px 0px -30px 0px' }
      );

      els.forEach(function(el) {
        if (!el.classList.contains('visible')) {
          observer.observe(el);
        }
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initReveal);
    } else {
      initReveal();
    }
  </script>
</body>
</html>
